    "import cv2\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 1. Change Image Brightness using Thresholding\n",
    "img = cv2.imread(\"C:\\\\Users\\\\nstip\\\\Downloads\\\\sample.jpg.jpeg\", cv2.IMREAD_GRAYSCALE)\n",
    "ret, binary = cv2.threshold(img, 127, 255, cv2.THRESH_BINARY)\n",
    "\n",
    "plt.imshow(binary, cmap=\"gray\")\n",
    "plt.title(\"Thresholded (Black & White)\")\n",
    "plt.axis(\"on\")\n",
    "plt.show()\n"
   ]
  },
